{
    "name": "startermint/stackmint-auth",
    "description": "Authentication module for the Stackmint framework.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "wayfinder/core": "0.0.19"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:Startermint/wayfinder-core.git",
            "no-api": true
        }
    ],
    "autoload": {
        "psr-4": {
            "Modules\\Auth\\": ""
        }
    }
}
